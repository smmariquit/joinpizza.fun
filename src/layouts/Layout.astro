---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Pizza & Friends", 
  description = "Unexpectedly a tech community! From dinner meetups to Discord calls, we make cool stuff and try not to take it too seriously." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://joinpizza.fun" />
    <meta property="og:site_name" content="Pizza & Friends" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/logo.png" />
    
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/logo.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet">
    
    <!-- Define the CSS variables globally so globals.css picks them up -->
    <style is:inline>
      :root {
        --font-geist-sans: 'Geist', sans-serif;
        --font-geist-mono: 'Geist Mono', monospace;
        --font-libre-baskerville: 'Libre Baskerville', serif;
        --font-caveat: 'Caveat', cursive;
      }
    </style>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
