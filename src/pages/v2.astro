---
import Layout from '../layouts/Layout.astro';
import ACTIVITIES from '../data/events.json';
---

<Layout title="v2.0.0 | Pizza & Friends" description="The Grid. A structured, editorial approach." theme="v2">
  <main id="main-content" class="page-wrapper">
    <!-- Hero Section -->
    <div class="hero-section">
      <div class="hero-pizza-wrap">
        <img
          class="hero-pizza"
          src="/pizza_1f355.webp"
          alt="🍕"
          width="120"
          height="120"
        />
      </div>

      <div class="hero-title">
        <div class="hero-title-text">
          <span class="typed-word" style="display: inline-block; min-width: 4.2em">
            <span id="type-text"></span><span class="cursor-blink"></span>
          </span>
        </div>
      </div>

      <p class="hero-tagline">
        Unexpectedly a tech community! From dinner meetups to Discord calls, we make cool stuff and try not to take it too seriously.
      </p>

      <div class="cta-row">
        <a class="cta-primary" href="https://discord.gg/TrycsErM4R" target="_blank" rel="noopener noreferrer">
          Join the table 🍕
        </a>
        <div class="social-icons">
          <a href="https://instagram.com/pizzaplusfriends" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5 5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3z"/></svg>
          </a>
          <a href="https://facebook.com/pizzaplusfriends" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
          </a>
          <a href="https://linkedin.com/company/pizzafriends" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Activities Grid -->
    <div class="activities-section">
      <h2 class="section-title">What we've been up to</h2>
      <div class="activities-grid">
        {ACTIVITIES.map((activity, i) => (
          <div class="activity-card">
            <div class="activity-image-wrap">
              {activity.image ? (
                <img
                  src={activity.image}
                  alt={activity.title}
                  width="280"
                  height="280"
                  class="activity-image"
                />
              ) : activity.video ? (
                <video
                  src={activity.video}
                  width="280"
                  height="280"
                  class="activity-image"
                  autoplay
                  loop
                  muted
                  playsinline
                ></video>
              ) : null}
            </div>
            <div class="activity-info">
              <h3 class="activity-title">{activity.title}</h3>
              <span class="activity-date">{activity.date}</span>
              <p class="activity-desc">{activity.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Contact -->
    <div class="footer-contact">
      <p class="contact-line">
        Questions? Contact <a href="mailto:johnyumul.ph@gmail.com">John</a> or <a href="mailto:semariquit@gmail.com">Simonee</a>
      </p>
      <p class="contact-line" style="margin-top: 2rem;">
        <a href="/archive" style="background: var(--light-gray); color: var(--dark); padding: 0.6rem 1.2rem; border-radius: 100px; text-decoration: none; font-weight: 600; font-size: 0.95rem; transition: background 0.2s; display: inline-block;" onmouseover="this.style.background='#d8ccc3'" onmouseout="this.style.background='var(--light-gray)'">&larr; Back to Archive</a>
      </p>
    </div>
  </main>
</Layout>

<style>
  /* ─── PAGE WRAPPER ─── */
  .page-wrapper {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ─── HERO SECTION ─── */
  .hero-section {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
  }

  .hero-pizza-wrap {
    margin-bottom: 2rem;
    z-index: 10;
  }

  .hero-pizza {
    width: 80px;
    height: 80px;
    margin-bottom: 0;
    filter: drop-shadow(0 8px 24px rgba(242, 70, 56, 0.18));
    animation: float 4s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-12px) rotate(3deg); }
  }

  /* ─── GIANT TEXT ─── */
  .hero-title {
    position: relative;
    z-index: 4;
    width: 100%;
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .hero-title-text {
    font-family: 'Libre Baskerville', serif;
    font-weight: 700;
    color: var(--dark);
    line-height: 1;
    letter-spacing: -0.03em;
    white-space: nowrap;
    font-size: clamp(3.5rem, 10vw, 9rem);
  }

  .hero-ampersand {
    font-family: 'Libre Baskerville', serif;
    font-weight: 400;
    font-style: italic;
    color: var(--dark);
    font-size: clamp(2.5rem, 5vw, 5rem);
    margin: 0 0.15em;
    vertical-align: middle;
    opacity: 0.5;
  }

  /* ─── TYPED WORD ─── */
  .typed-word {
    color: var(--red);
    font-family: 'Libre Baskerville', serif;
    font-weight: 700;
    position: relative;
    display: inline;
  }

  .cursor-blink {
    display: inline-block;
    width: 3px;
    background: var(--red);
    margin-left: 2px;
    animation: blink 0.7s step-end infinite;
    vertical-align: baseline;
    height: 0.75em;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  /* ─── TAGLINE ─── */
  .hero-tagline {
    font-size: 1rem;
    color: var(--gray);
    max-width: 480px;
    line-height: 1.5;
    margin: 0 auto 1.25rem;
  }

  /* ─── CTA ─── */
  .cta-row {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: var(--red);
    color: var(--white);
    font-family: 'Libre Baskerville', serif;
    font-weight: 700;
    font-size: 0.95rem;
    border: none;
    border-radius: 100px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.25s;
    box-shadow: 0 4px 16px rgba(242, 70, 56, 0.25);
  }

  .cta-primary:hover {
    background: #d93a2e;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(242, 70, 56, 0.35);
  }

  /* ─── SOCIAL ICONS ─── */
  .social-icons {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .social-icons a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1.5px solid var(--light-gray);
    color: var(--dark);
    transition: all 0.25s;
  }

  .social-icons a:hover {
    border-color: var(--red);
    color: var(--red);
    transform: translateY(-2px);
  }

  /* ─── ACTIVITIES SECTION & GRID ─── */
  .activities-section {
    width: 100%;
    max-width: 1200px;
    padding: 4rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-title {
    font-family: 'Libre Baskerville', serif;
    font-weight: 700;
    font-size: 2rem;
    color: var(--dark);
    margin-bottom: 3rem;
    text-align: center;
  }

  .activities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
    width: 100%;
  }

  .activity-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--off-white);
    border: 1px solid var(--light-gray);
    border-radius: 24px;
    padding: 1.5rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .activity-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.05);
    border-color: var(--red);
  }

  .activity-image-wrap {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 16px;
    overflow: hidden;
    background: var(--white);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--light-gray);
  }

  .activity-image {
    height: 90%;
    width: auto;
    object-fit: contain;
  }

  .activity-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .activity-title {
    font-family: 'Libre Baskerville', serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--dark);
    line-height: 1.2;
  }

  .activity-date {
    font-size: 0.85rem;
    color: var(--red);
    font-family: 'Libre Baskerville', serif;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .activity-desc {
    font-size: 0.95rem;
    color: var(--gray);
    line-height: 1.5;
    margin: 0;
  }

  /* ─── CONTACT LINE ─── */
  .footer-contact {
    padding: 4rem 2rem;
    text-align: center;
  }

  .contact-line {
    font-size: 1.1rem;
    color: var(--gray);
    opacity: 0.8;
  }

  .contact-line a {
    color: var(--red);
    text-decoration: none;
    font-weight: 600;
  }

  .contact-line a:hover {
    text-decoration: underline;
  }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .hero-pizza {
      width: 80px;
      height: 80px;
    }

    .hero-title-text {
      white-space: normal;
    }

    .activity-image-wrap {
      width: 160px;
      height: 160px;
    }
  }
</style>

<script>
  const words = ["pizza", "friends"];
  let wordIndex = 0;
  let text = "";
  let isDeleting = false;
  let typeSpeed = 130;
  let deleteSpeed = 70;
  
  function type() {
    const el = document.getElementById("type-text");
    if (!el) return;
    
    const currentWord = words[wordIndex];
    if (isDeleting) {
      text = currentWord.substring(0, text.length - 1);
    } else {
      text = currentWord.substring(0, text.length + 1);
    }
    
    el.textContent = text;
    
    let speed = isDeleting ? deleteSpeed : typeSpeed;
    
    if (!isDeleting && text === currentWord) {
      speed = 2200;
      isDeleting = true;
    } else if (isDeleting && text === "") {
      isDeleting = false;
      wordIndex = (wordIndex + 1) % words.length;
      speed = 350;
    }
    
    setTimeout(type, speed);
  }
  
  // Start the typing animation
  setTimeout(type, typeSpeed);
</script>
