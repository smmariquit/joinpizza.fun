---
import Layout from '../layouts/Layout.astro';
import LegalMicroLink from '../components/LegalMicroLink.astro';
import ACTIVITIES from '../data/events.json';
import fs from 'node:fs';
import path from 'node:path';

// Deterministic rotation offsets for the scattered polaroid look
const ROTATIONS = [-3, 2.5, -1.5, 3, -2, 1.5, 4, -2.5, 2, -3.5, 1, -4];

// Dynamically gather all images & videos from /irl for the marquee
const irlDir = path.join(process.cwd(), 'public/irl');
const irlFiles = fs.readdirSync(irlDir)
.filter(f => /\.webp$/i.test(f)) // photos only: no videos in the marquee (performance + dedup)
.sort(() => 0.5 - Math.random()); // shuffle for variety
---

<Layout>
 <main id="main-content" class="page-wrapper">
 <!, Hero Section, >
 <section class="hero-section" aria-label="Welcome to Pizza & Friends">
 <div class="hero-center">
 <h1 class="hero-title">
 Pizza <span class="hero-ampersand">&</span> Friends
 </h1>

 <p class="hero-tagline">
 Unexpectedly a tech community! From dinner meetups to Discord calls, we make cool stuff and try not to take it too seriously.
 </p>

 <div class="cta-stack">
 <a class="cta-primary" href="https://discord.gg/TrycsErM4R" target="_blank" rel="noopener noreferrer">
 Join the table
 </a>
 <nav class="social-icons" aria-label="Social media links">
 <a href="https://instagram.com/pizzaplusfriends" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Instagram">
 <svg focusable="false" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M7.8 2h8.4C19.4 2 22 4.6 22 7.8v8.4a5.8 5.8 0 0 1-5.8 5.8H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2m-.2 2A3.6 3.6 0 0 0 4 7.6v8.8C4 18.39 5.61 20 7.6 20h8.8a3.6 3.6 0 0 0 3.6-3.6V7.6C20 5.61 18.39 4 16.4 4H7.6m9.65 1.5a1.25 1.25 0 0 1 1.25 1.25A1.25 1.25 0 0 1 17.25 8 1.25 1.25 0 0 1 16 6.75a1.25 1.25 0 0 1 1.25-1.25M12 7a5 5 0 0 1 5 5 5 5 0 0 1-5 5 5 5 0 0 1-5-5 5 5 0 0 1 5-5m0 2a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3z"/></svg>
 </a>
 <a href="https://facebook.com/pizzaplusfriends" target="_blank" rel="noopener noreferrer" aria-label="Follow us on Facebook">
 <svg focusable="false" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1.45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/></svg>
 </a>
 <a href="https://linkedin.com/company/pizzafriends" target="_blank" rel="noopener noreferrer" aria-label="Follow us on LinkedIn">
 <svg focusable="false" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0.93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
 </a>
 </nav>
 </div>
 </div>

 <!, Horizontal Marquee with ALL /irl photos, >
 <div class="hero-marquee" role="img" aria-label="A scrolling gallery of community photos from Pizza & Friends meetups and events">
 <div class="marquee-track" aria-hidden="true">
 {/* First set: photos only */}
 {irlFiles.map((file, i) => {
 const rot = ROTATIONS[i % ROTATIONS.length];
 return (
 <div class="polaroid marquee-photo" style={`, rotation: ${rot}deg`}>
 <div class="polaroid-image-wrap">
 <img
 src={`/irl/${file}`}
 alt=""
 width="220"
 height="220"
 class="polaroid-image"
 loading={i === 0 ? 'eager' : 'lazy'}
 fetchpriority={i === 0 ? 'high' : 'auto'}
 />
 </div>
 </div>
 );
 })}
 {/* Duplicate set for smooth loop: aria-hidden so screen readers don't double-read */}
 {irlFiles.map((file, i) => {
 const rot = ROTATIONS[i % ROTATIONS.length];
 return (
 <div class="polaroid marquee-photo" style={`, rotation: ${rot}deg`} aria-hidden="true">
 <div class="polaroid-image-wrap">
 <img
 src={`/irl/${file}`}
 alt=""
 width="220"
 height="220"
 class="polaroid-image"
 loading="lazy"
 />
 </div>
 </div>
 );
 })}
 </div>
 </div>
 </section>

 <!, Activities Grid, >
 <section class="activities-section" aria-label="Recent events">
 <h2 class="section-title">What we've been up to</h2>
 <div class="polaroid-wall">
 {ACTIVITIES.map((activity, i) => {
 const rot = ROTATIONS[i % ROTATIONS.length];
 return (
 <div
 class="polaroid"
 style={`, rotation: ${rot}deg`}
 >
 <div class="tape"></div>
 <div class="polaroid-image-wrap">
 {activity.video ? (
 <video
 tabindex="-1"
 src={activity.video}
 autoplay
 loop
 muted
 playsinline
 class="polaroid-video"
 aria-label={activity.title}
 >
 {activity.captions && (
 // No `default`: this is a muted autoplay video; captions would auto-render on screen
 <track kind="captions" src={activity.captions} srclang="en" label="English" />
 )}
 </video>
 ) : (
 <img
 src={activity.image}
 alt={activity.title}
 width="400"
 height="400"
 class="polaroid-image"
 loading="lazy"
 />
 )}
 </div>
 <div class="polaroid-info">
 <h3 class="polaroid-title">{activity.title}</h3>
 <span class="polaroid-date">{activity.date}</span>
 </div>
 </div>
 );
 })}
 </div>
 </section>

 <!, Contact, >
 <footer class="footer-contact">
 <p class="contact-line">
 Questions? Contact <a href="mailto:johnyumul.ph@gmail.com">John</a> or <a href="mailto:semariquit@gmail.com">Simonee</a>.
 </p>
 <p class="contact-line" style="margin-top: 0.5rem; font-size: 0.95em;">
 <a href="/archive">View Design Archive</a>
 </p>
 <LegalMicroLink />
 </footer>
 </main>
</Layout>
